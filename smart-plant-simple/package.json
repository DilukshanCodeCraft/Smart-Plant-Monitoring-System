{
  "name": "smart-plant-simple",
  "version": "1.0.0",
  "private": true,
  "description": "Simplified Smart Plant Monitoring System",
  "scripts": {
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "npm --prefix backend run dev",
    "dev:backend:isolated": "npm --prefix backend run dev:isolated",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:isolated": "concurrently \"npm:dev:backend:isolated\" \"npm:dev:frontend\"",
    "build": "npm --prefix frontend run build",
    "start": "npm --prefix backend run start"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
